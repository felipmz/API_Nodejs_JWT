generator client {
  provider = "prisma-client"
  //provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String    
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  createdAt DateTime  @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}